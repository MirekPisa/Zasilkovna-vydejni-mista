<div id="zasilkovna-pickup-block" style="margin: 16px 0;">
  <h3 style="margin-bottom: 8px; font-size: 16px; font-weight: 600;">{{ block.settings.heading }}</h3>

  <button
    id="zasilkovna-select-btn"
    type="button"
    style="
      background-color: {{ block.settings.button_color }};
      color: #fff;
      border: none;
      padding: 12px 24px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      width: 100%;
    "
  >
    {{ block.settings.button_text }}
  </button>

  <div id="zasilkovna-selected-point" style="display: none; margin-top: 12px; padding: 12px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px;">
    <p style="margin: 0; font-weight: 600; color: #166534;">Vybráno výdejní místo:</p>
    <p id="zasilkovna-point-name" style="margin: 4px 0 0; color: #15803d;"></p>
    <p id="zasilkovna-point-address" style="margin: 2px 0 0; font-size: 13px; color: #166534;"></p>
    <button
      id="zasilkovna-change-btn"
      type="button"
      style="margin-top: 8px; background: none; border: 1px solid #166534; color: #166534; padding: 6px 16px; border-radius: 4px; cursor: pointer; font-size: 13px;"
    >
      Změnit výdejní místo
    </button>
  </div>

  <div id="zasilkovna-saving" style="display: none; margin-top: 8px; font-size: 13px; color: #6b7280;">
    Ukládám výběr…
  </div>
  <div id="zasilkovna-error" style="display: none; margin-top: 8px; font-size: 13px; color: #dc2626;"></div>

  {%- comment -%}
    Skryté inputs jako záloha pro témata s klasickým form submittem.
    Primárně se data ukládají přes Cart API (/cart/update.js) níže.
  {%- endcomment -%}
  <input type="hidden" name="attributes[packeta_point_id]" id="zasilkovna-point-id-input" value="">
  <input type="hidden" name="attributes[packeta_point_name]" id="zasilkovna-point-name-input" value="">
  <input type="hidden" name="attributes[packeta_point_address]" id="zasilkovna-point-address-input" value="">
</div>

<script src="https://widget.packeta.com/v6/www/js/library.js"></script>
<script>
(function() {
  var API_KEY = '{{ block.settings.api_key }}';
  var selectBtn = document.getElementById('zasilkovna-select-btn');
  var changeBtn = document.getElementById('zasilkovna-change-btn');
  var selectedDiv = document.getElementById('zasilkovna-selected-point');
  var savingEl = document.getElementById('zasilkovna-saving');
  var errorEl = document.getElementById('zasilkovna-error');
  var pointNameEl = document.getElementById('zasilkovna-point-name');
  var pointAddressEl = document.getElementById('zasilkovna-point-address');
  var pointIdInput = document.getElementById('zasilkovna-point-id-input');
  var pointNameInput = document.getElementById('zasilkovna-point-name-input');
  var pointAddressInput = document.getElementById('zasilkovna-point-address-input');

  // Restore previously selected point from sessionStorage
  try {
    var stored = sessionStorage.getItem('packeta_selected_point');
    if (stored) {
      var p = JSON.parse(stored);
      showSelectedPoint(p.name, p.address, p.id);
    }
  } catch(e) {}

  function showSelectedPoint(name, address, id) {
    pointNameEl.textContent = name;
    pointAddressEl.textContent = address;
    pointIdInput.value = id;
    pointNameInput.value = name;
    pointAddressInput.value = address;
    selectedDiv.style.display = 'block';
    selectBtn.style.display = 'none';
  }

  function saveToCart(id, name, address) {
    savingEl.style.display = 'block';
    errorEl.style.display = 'none';

    // Also move hidden inputs into cart form if found (belt and suspenders)
    var cartForm = document.querySelector('form[action="/cart"]') || document.querySelector('form[action*="/cart"]');
    if (cartForm) {
      ['zasilkovna-point-id-input', 'zasilkovna-point-name-input', 'zasilkovna-point-address-input'].forEach(function(elId) {
        var el = document.getElementById(elId);
        if (el && el.parentElement !== cartForm) {
          cartForm.appendChild(el);
        }
      });
    }

    // Primary method: Cart Attributes API
    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({
        attributes: {
          packeta_point_id: String(id),
          packeta_point_name: name,
          packeta_point_address: address
        }
      })
    })
    .then(function(res) {
      savingEl.style.display = 'none';
      if (!res.ok) {
        errorEl.textContent = 'Nepodařilo se uložit výdejní místo. Zkuste znovu.';
        errorEl.style.display = 'block';
      } else {
        try {
          sessionStorage.setItem('packeta_selected_point', JSON.stringify({ id: id, name: name, address: address }));
        } catch(e) {}
      }
    })
    .catch(function() {
      savingEl.style.display = 'none';
      errorEl.textContent = 'Chyba sítě. Výdejní místo může být nezaznamenáno.';
      errorEl.style.display = 'block';
    });
  }

  function openWidget() {
    if (!window.Packeta || !window.Packeta.Widget) {
      setTimeout(openWidget, 500);
      return;
    }
    Packeta.Widget.pick({
      apiKey: API_KEY,
      country: 'cz',
      language: 'cs',
      appIdentity: 'shopify-zasilkovna-printybob'
    }, function(point) {
      if (!point) return;
      var address = point.formattedAddress || (point.street + ', ' + point.city + ' ' + point.zip);
      showSelectedPoint(point.name, address, point.id);
      saveToCart(point.id, point.name, address);
    });
  }

  selectBtn.addEventListener('click', openWidget);
  changeBtn.addEventListener('click', function() {
    selectedDiv.style.display = 'none';
    selectBtn.style.display = 'block';
    openWidget();
  });
})();
</script>

{% schema %}
{
  "name": "Zasilkovna Pickup",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_key",
      "label": "Packeta API klíč",
      "info": "Váš API klíč z Packeta klientského portálu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Výběr výdejního místa Zásilkovny"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Text tlačítka",
      "default": "Vybrat výdejní místo"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Barva tlačítka",
      "default": "#c8232c"
    }
  ]
}
{% endschema %}
